{
  "name": "advanced-storm-inc",
  "version": "1.0.3-alpha.17",
  "description": "Cross-platform desktop and web build of the STORM_INC tropical cyclone simulator.",
  "main": "electron/main.cjs",
  "author": "EnceladusCat",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack:desktop": "electron-builder --mac --linux --win --x64 --dir",
    "build:desktop": "electron-builder --mac --linux --win --x64",
    "pack:win": "electron-builder --win --x64 --dir",
    "build:win": "electron-builder --win --x64",
    "pack:mac": "electron-builder --mac --x64 --arm64 --dir",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "pack:linux": "electron-builder --linux --x64 --dir",
    "build:linux": "electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.enceladuscat.storminc",
    "productName": "STORM_INC",
    "buildVersion": "1.0.3.17",
    "copyright": "Copyright (c) 2026 EnceladusCat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "Storm_Inc/**/*",
      "README.md",
      "DISCORD_OVERLAY.md",
      "build/icon.ico",
      "build/icon.icns",
      "build/icon.png",
      "model.onnx",
      "weather_mapping.json",
      "sz_wind_data_updated.csv"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "build/icon.icns"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "executableName": "STORM_INC",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "icon": "build/icon.icns",
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "STORM_INC"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
